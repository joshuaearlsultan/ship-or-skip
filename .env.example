# Copy this file to .env.local before running npm run dev.
# .env.local is gitignored and never committed.

# Required for live evaluations — get your key at console.anthropic.com
# Not needed when USE_MOCK_EVALUATIONS is unset or set to any value other than "false"
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# API base URL — defaults to https://api.anthropic.com when unset
# Override only if routing through a custom proxy or gateway
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Model to use — any model available on your key is valid
ANTHROPIC_MODEL=claude-opus-4-5

# Set to "false" to make live API calls; any other value (or absent) uses mock data
USE_MOCK_EVALUATIONS=true
