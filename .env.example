# Copy this file to .env.local before running npm run dev.
# .env.local is gitignored and never committed.

# ── AI provider mode ───────────────────────────────────────────────────────
# true  → company AI gateway (internal use / local dev)
# false → direct Anthropic API (public Vercel deployment)
USE_COMPANY_GATEWAY=true

# ── Company gateway (USE_COMPANY_GATEWAY=true) ─────────────────────────────
COMPANY_GATEWAY_URL=https://your-gateway-hostname
COMPANY_GATEWAY_KEY=your-gateway-key-here

# ── Direct Anthropic (USE_COMPANY_GATEWAY=false) ───────────────────────────
# Get your key at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# Optional: override base URL (defaults to https://api.anthropic.com)
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# ── Shared settings ────────────────────────────────────────────────────────
# Model name — must be valid for whichever provider is active
# Gateway examples : claude-quality, claude-fast
# Anthropic examples: claude-3-5-sonnet-20241022, claude-3-5-haiku-20241022
ANTHROPIC_MODEL=claude-quality

# Set to "false" to make live API calls; any other value (or absent) uses mock data
USE_MOCK_EVALUATIONS=true
